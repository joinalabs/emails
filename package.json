{
  "name": "@joinalabs/emails",
  "version": "0.1.1",
  "description": "React Email templates for Joina event SaaS flows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts/husky-if-present.mjs"
  ],
  "scripts": {
    "build": "tsup",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "preview:html": "npm run build && node scripts/render-email-samples.mjs",
    "dev": "email dev",
    "prepare": "node scripts/husky-if-present.mjs",
    "prepublishOnly": "npm run build && npm run check && npm run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@react-email/components": "^0.5.0",
    "@react-email/render": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@react-email/preview-server": "^5.0.0",
    "husky": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^5.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joinalabs/emails.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
